# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gym-pulse

# API Configuration
# Change this to your actual Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Path to the service account JSON file
# Ruta relativa a la raíz del proyecto (válida en local y en Docker con WORKDIR /app)
FIREBASE_SERVICE_ACCOUNT=firebase/g-pluse-firebase-adminsdk-fbsvc-24ada3e42f.json

# JWT (backend-issued access tokens for API auth)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Resend (transactional email)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_key_here
# Use onboarding@resend.dev for testing without a verified domain
MAIL_FROM="G-Pulse <onboarding@resend.dev>"
APP_NAME=G-Pulse

# Supabase database connections
# DATABASE_URL  → Transaction pooler (port 6543) — para queries en runtime
# DIRECT_URL    → Session mode (port 5432)        — para migraciones de Prisma
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase Storage Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key-here
SUPABASE_BUCKET=exercise-media

