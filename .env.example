# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gym-pulse

# API Configuration
# Change this to your actual Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Path to the service account JSON file
# Ruta relativa a la raíz del proyecto (válida en local y en Docker con WORKDIR /app)
FIREBASE_SERVICE_ACCOUNT=firebase/g-pluse-firebase-adminsdk-fbsvc-24ada3e42f.json

# JWT (backend-issued access tokens for API auth)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# The DATABASE_URL is constructed automatically in docker-compose.yml
# but can be defined here if needed for local scripts:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym-pulse?schema=public
