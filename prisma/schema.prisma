generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String?
  googleId       String?   @unique
  name           String?
  username       String?   @unique
  avatarUrl      String?
  bio            String?
  role           Role      @default(USER)
  level          UserLevel @default(BEGINNER)
  trainingStreak Int       @default(0)
  quotasUsed     Int       @default(0)
  lastQuotaReset DateTime  @default(now())

  // AI Quotas
  aiPromptCount    Int      @default(0)
  lastAiPromptDate DateTime @default(now())

  plan         SubscriptionPlan @default(BASIC)
  pushEnabled  Boolean          @default(true)
  restSeconds  Int              @default(90)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  activityLogs  ActivityLog[]
  deviceTokens DeviceToken[]
  routines      Routine[]
  subscription  Subscription?
  favorites     UserFavorite[]
  routineLikes  RoutineLike[]
  exerciseMedia ExerciseMedia[]
  following     UserFollow[]  @relation("UserFollowing")
  followers     UserFollow[]  @relation("UserFollowers")
  mediaLikes    MediaLike[]
  goals         Goal[]
  schedule      RoutineSchedule[]
  measurements  BodyMeasurement[]
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  platform   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BodyMeasurement {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @default(now())
  weightKg   Float?
  bodyFatPct Float?
  waistCm    Float?
  chestCm    Float?
  armCm      Float?
  legCm      Float?
  hipCm      Float?
  notes      String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date(sort: Desc)])
}

model Exercise {
  id           String   @id @default(uuid())
  name         Json
  description  Json?
  instructions Json?
  difficulty   String? // beginner, intermediate, expert
  mechanic     String? // compound, isolation
  force        String? // push, pull, static
  equipment    String?
  thumbnail    String?
  images_leip  Json?

  // Relations
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  primaryMuscles   Muscle[] @relation("PrimaryMuscles")
  secondaryMuscles Muscle[] @relation("SecondaryMuscles")

  media       ExerciseMedia[]
  routines    RoutineExercise[]
  workoutSets WorkoutSet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  exercises Exercise[]
}

model Muscle {
  id                 String     @id @default(uuid())
  name               String     @unique
  target             String? // Optional: grouping like 'arms', 'legs'
  primaryExercises   Exercise[] @relation("PrimaryMuscles")
  secondaryExercises Exercise[] @relation("SecondaryMuscles")
}

model ExerciseMedia {
  id         String    @id @default(uuid())
  url        String
  type       MediaType @default(IMAGE)
  exerciseId String
  exercise   Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  isPublic   Boolean   @default(false)
  isPaused   Boolean   @default(false)
  likes      Int       @default(0)
  caption    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  likedBy          MediaLike[]
  routineExercises RoutineExercise[]
}

enum MediaType {
  IMAGE
  GIF
  VIDEO
}

model Routine {
  id          String            @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean           @default(false)
  likes       Int               @default(0)
  creatorId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  activities  ActivityLog[]
  creator     User              @relation(fields: [creatorId], references: [id])
  exercises   RoutineExercise[]
  favoritedBy UserFavorite[]
  likedBy     RoutineLike[]
  scheduledFor RoutineSchedule[]
}

model RoutineExercise {
  id         String         @id @default(uuid())
  routineId  String
  exerciseId String
  mediaId    String?
  order      Int
  sets       Int?
  reps       Int?
  duration   Int?
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  routine    Routine        @relation(fields: [routineId], references: [id])
  media      ExerciseMedia? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
}

model UserFavorite {
  userId    String
  routineId String
  createdAt DateTime @default(now())
  routine   Routine  @relation(fields: [routineId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, routineId])
}

model RoutineLike {
  userId    String
  routineId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@id([userId, routineId])
  @@index([routineId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  routineId String?
  date      DateTime @default(now())
  duration  Int
  calories  Int
  routine   Routine? @relation(fields: [routineId], references: [id], onDelete: SetNull)
  user      User     @relation(fields: [userId], references: [id])
  sets      WorkoutSet[]
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @unique
  plan      SubscriptionPlan
  startDate DateTime         @default(now())
  endDate   DateTime?
  isActive  Boolean          @default(true)
  user      User             @relation(fields: [userId], references: [id])
}

enum UserLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubscriptionPlan {
  BASIC
  PRO
  EXPERT
}

enum Role {
  USER
  ADMIN
}

enum GoalType {
  WEIGHT
  WORKOUTS_PER_WEEK
  CALORIES_BURN
  DURATION_MINUTES
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  ABANDONED
}

model Goal {
  id           String     @id @default(uuid())
  userId       String
  type         GoalType
  targetValue  Float
  currentValue Float      @default(0.0)
  startDate    DateTime   @default(now())
  endDate      DateTime?
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiResponseCache {
  id        String   @id @default(uuid())
  prompt    String   @unique
  response  String
  createdAt DateTime @default(now())
}

model WorkoutSet {
  id            String      @id @default(uuid())
  activityLogId String
  exerciseId    String
  setNumber     Int
  reps          Int
  weight        Float?      // Opcional para peso corporal
  activityLog   ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])
  createdAt     DateTime    @default(now())
}

model Dictionary {
  id           String @id @default(uuid())
  type         String // ej: 'equipment', 'body_part', 'category'
  key          String // ej: 'body weight', 'dumbbell', 'waist'
  translations Json   // ej: { "en": "body weight", "es": "peso corporal", "it": "peso corporeo", "tr": "vücut ağırlığı" }

  @@unique([type, key])
}

model UserFollow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model MediaLike {
  userId    String
  mediaId   String
  createdAt DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media ExerciseMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([userId, mediaId])
  @@index([mediaId])
}

model RoutineSchedule {
  userId    String
  dayOfWeek Int       // 0..6 ; 0=Sun, 6=Sat
  routineId String
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId],    references: [id], onDelete: Cascade)
  routine   Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@id([userId, dayOfWeek])
  @@index([routineId])
}
